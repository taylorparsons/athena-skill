#!/bin/bash
# Post-commit hook: Auto-update athena-index.md when features complete
# Install: cp scripts/hooks/post-commit .git/hooks/post-commit && chmod +x .git/hooks/post-commit

REPO_ROOT="$(git rev-parse --show-toplevel)"
OWL_SCRIPT="$REPO_ROOT/scripts/owl"

# Check if owl script exists
if [ ! -f "$OWL_SCRIPT" ]; then
    exit 0
fi

# Check if commit message indicates feature completion
COMMIT_MSG=$(git log -1 --pretty=%B)

# Look for patterns indicating feature is done
if echo "$COMMIT_MSG" | grep -qiE "(Status: Done|feature complete|mark.*done|archive.*feature)"; then
    echo "🦉 Owl: Detected feature completion, updating athena-index.md..."
    
    # Extract feature ID from commit message if present
    FEATURE_ID=$(echo "$COMMIT_MSG" | grep -oE "Feature: [a-zA-Z0-9-]+" | sed 's/Feature: //')
    
    if [ -n "$FEATURE_ID" ]; then
        echo "🦉 Owl: Archiving feature $FEATURE_ID..."
        "$OWL_SCRIPT" archive "$FEATURE_ID" 2>/dev/null || true
    fi
    
    # Always regenerate athena-index.md to catch any status changes
    echo "🦉 Owl: Regenerating athena-index.md..."
    "$OWL_SCRIPT" update-index > /dev/null 2>&1

    # Check if athena-index.md changed
    if ! git diff --quiet docs/athena-index.md 2>/dev/null; then
        echo "🦉 Owl: athena-index.md updated, staging changes..."
        git add docs/athena-index.md
        
        # Also check if progress.txt was trimmed
        if ! git diff --quiet docs/progress.txt 2>/dev/null; then
            echo "🦉 Owl: progress.txt archived, staging changes..."
            git add docs/progress.txt
        fi
        
        git commit --amend --no-edit --no-verify
        echo "✅ athena-index.md automatically updated"
    else
        echo "✅ athena-index.md already up to date"
    fi
fi
